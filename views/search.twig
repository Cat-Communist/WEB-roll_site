    <form class="row"> 
        <label for="inputState" class="form-label">Вид рикролла</label>
        <div class="col">
			<select name="type" id="inputState" class="form-select">
				<option selected value="все">Все</option>
				<option value="рик">Рик</option>
				<option value="нерик">Нерик</option>
			</select>
		</div>
		<div class="col">
			<input type="text" name="title" class="form-control" placeholder="Название" aria-label="First name">
		</div>
		<div class="col">
			<input type="text" name="description" class="form-control" placeholder="Описание" aria-label="Last name">
		</div>
        <div class="col">
            <button type="submit" class="btn btn-primary">Найти</button>
        </div>
	</form>

	{% for meme in memes %}
		<ul>
			<li>
				<a href="/rickrolls{{meme.id}}">{{meme.title}}</a>
				<ol>
					<li>
						{{meme.description}}
					</li>
				</ol>
			</li>
		</ul>
	{% endfor %}

{% endblock %}
