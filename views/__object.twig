{% extends "__layout.twig" %}

{% block content %}
<div class="alert alert-info">Current url: ({{url}})</div>
<ul class="nav nav-pills">
  <li class="nav-item">
    <a class="btn {{is_image ? "btn-primary"}}" href="{{image_url}}">Картинка</a>
  </li>
  <li class="nav-item">
    <a class="btn {{is_info ? "btn-primary"}}" href="{{info_url}}">Описание</a>
  </li>
</ul>
{% block object_content %}{% endblock %}
{% endblock %}